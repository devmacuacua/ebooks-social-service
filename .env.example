# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3003
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── Base de dados (PostgreSQL via Prisma) ────────────────────────────────────
DATABASE_URL=postgresql://ebooks:ebooks_secret@localhost:5432/social_db

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://ebooks:ebooks_secret@localhost:5672

# ─── Twitter / X (OAuth 1.0a) ────────────────────────────────────────────────
# Criar app em: https://developer.twitter.com
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# ─── Facebook (Graph API) ─────────────────────────────────────────────────────
# Criar app em: https://developers.facebook.com
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_TOKEN=
